{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GitHub Context Fetch",
  "description": "Fetched GitHub configuration and code files with 404 error handling",
  "type": "object",
  "required": ["job_id", "job_metadata", "github_fetches"],
  "properties": {
    "job_id": {
      "type": "string",
      "description": "AAP job ID"
    },
    "job_metadata": {
      "type": "object",
      "description": "Parsed metadata from job name (platform, catalog_item, env, guid)",
      "properties": {
        "platform": {"type": "string"},
        "catalog_item": {"type": "string"},
        "env": {"type": "string"},
        "guid": {"type": "string"},
        "warnings": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "github_fetches": {
      "type": "array",
      "description": "GitHub files fetched for each failed task (matches step1 by task_path)",
      "items": {
        "type": "object",
        "required": ["task_path", "location", "fetched_configs", "fetched_workload"],
        "properties": {
          "task_path": {
            "type": "string",
            "description": "Original task_path from step1 (used for matching)"
          },
          "task": {
            "type": "string",
            "description": "Task name for readability"
          },
          "location": {
            "type": "object",
            "description": "Parsed GitHub location information",
            "properties": {
              "original_path": {"type": "string"},
              "parsed": {
                "type": "object",
                "properties": {
                  "owner": {"type": "string"},
                  "repo": {"type": "string"},
                  "file_path": {"type": "string"},
                  "line_number": {"type": "integer"}
                }
              }
            }
          },
          "fetched_configs": {
            "type": "object",
            "description": "AgnosticV config files by purpose (common_yaml, platform_account_yaml, environment_yaml)",
            "additionalProperties": {
              "oneOf": [
                {
                  "type": "object",
                  "description": "Successfully fetched config",
                  "properties": {
                    "path": {"type": "string"},
                    "content": {"type": "string"},
                    "sha": {"type": "string"},
                    "size": {"type": "number"},
                    "paths_tried": {
                      "type": "array",
                      "description": "Present when multiple paths were tried",
                      "items": {
                        "type": "object",
                        "properties": {
                          "path": {"type": "string"},
                          "status": {"type": "string", "enum": ["success", "404"]}
                        },
                        "required": ["path", "status"]
                      }
                    }
                  },
                  "required": ["path", "content", "sha", "size"]
                },
                {
                  "type": "object",
                  "description": "Single path 404 error",
                  "properties": {
                    "error": {"type": "string", "enum": ["not_found"]},
                    "path": {"type": "string"}
                  },
                  "required": ["error", "path"]
                },
                {
                  "type": "object",
                  "description": "Multiple paths failed",
                  "properties": {
                    "error": {"type": "string", "enum": ["all_paths_failed"]},
                    "paths_tried": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "path": {"type": "string"},
                          "status": {"type": "string", "enum": ["404"]}
                        },
                        "required": ["path", "status"]
                      }
                    },
                    "mcp_verified": {
                      "type": "boolean",
                      "description": "Whether MCP tools were used to verify 404"
                    },
                    "mcp_findings": {
                      "type": "string",
                      "description": "MCP verification findings (parser_bug, file_missing, case_sensitivity, etc.)"
                    }
                  },
                  "required": ["error", "paths_tried"]
                }
              ]
            }
          },
          "fetched_workload": {
            "type": "object",
            "description": "AgnosticD workload files by purpose (role_defaults, failed_task_code)",
            "additionalProperties": {
              "oneOf": [
                {
                  "type": "object",
                  "description": "Successfully fetched workload",
                  "properties": {
                    "path": {"type": "string"},
                    "content": {"type": "string"},
                    "sha": {"type": "string"},
                    "size": {"type": "number"},
                    "paths_tried": {
                      "type": "array",
                      "description": "Present when multiple paths were tried",
                      "items": {
                        "type": "object",
                        "properties": {
                          "path": {"type": "string"},
                          "status": {"type": "string", "enum": ["success", "404"]}
                        },
                        "required": ["path", "status"]
                      }
                    }
                  },
                  "required": ["path", "content", "sha", "size"]
                },
                {
                  "type": "object",
                  "description": "Single path 404 error",
                  "properties": {
                    "error": {"type": "string", "enum": ["not_found"]},
                    "path": {"type": "string"}
                  },
                  "required": ["error", "path"]
                },
                {
                  "type": "object",
                  "description": "Multiple paths failed",
                  "properties": {
                    "error": {"type": "string", "enum": ["all_paths_failed"]},
                    "paths_tried": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "path": {"type": "string"},
                          "status": {"type": "string", "enum": ["404"]}
                        },
                        "required": ["path", "status"]
                      }
                    },
                    "mcp_verified": {
                      "type": "boolean",
                      "description": "Whether MCP tools were used to verify 404"
                    },
                    "mcp_findings": {
                      "type": "string",
                      "description": "MCP verification findings"
                    }
                  },
                  "required": ["error", "paths_tried"]
                }
              ]
            }
          }
        }
      }
    }
  }
}
