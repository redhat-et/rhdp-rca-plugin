{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Job Context",
  "description": "Extracted context from AAP job log for correlation",
  "type": "object",
  "required": ["job_id", "time_window"],
  "properties": {
    "job_id": {
      "type": "string",
      "description": "AAP job ID"
    },
    "job_name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["successful", "failed", "canceled", "running"]
    },
    "guid": {
      "type": "string",
      "description": "Unique deployment GUID (e.g., x1234)"
    },
    "namespace": {
      "type": "string",
      "description": "OCP namespace (e.g., sandbox-x1234-xx-ansiblebu)"
    },
    "cluster": {
      "type": "string",
      "description": "OCP cluster name"
    },
    "cloud_provider": {
      "type": "string"
    },
    "env_type": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": ["provision", "destroy", "stop", "start"]
    },
    "time_window": {
      "type": "object",
      "properties": {
        "started": {
          "type": "string",
          "format": "date-time"
        },
        "finished": {
          "type": "string",
          "format": "date-time"
        },
        "duration_seconds": {
          "type": "number"
        }
      }
    },
    "failed_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "task": {"type": "string"},
          "play": {"type": "string"},
          "role": {"type": "string"},
          "timestamp": {"type": "string"},
          "error_message": {"type": "string"},
          "task_path": {"type": "string"},
          "task_action": {"type": "string"},
          "duration": {"type": "number"},
          "stdout": {"type": ["string", "array"], "description": "stdout from the failed task result or event"},
          "stderr": {"type": "string", "description": "stderr from the failed task result"},
          "cmd": {"type": ["string", "array"], "description": "Command that was executed"},
          "rc": {"type": "integer", "description": "Return code of the failed command"}
        }
      }
    },
    "pod_references": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pod_name": {"type": "string"},
          "task": {"type": "string"},
          "timestamp": {"type": "string"}
        }
      }
    },
    "plays": {
      "type": "array",
      "items": {"type": "string"}
    },
    "roles": {
      "type": "array",
      "items": {"type": "string"}
    },
    "total_events": {
      "type": "integer"
    },
    "host_status_counts": {
      "type": "object"
    },
    "parsed_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_file": {
      "type": "string"
    }
  }
}
